use mod1;

print(mod1::val)

mod1::do()

# Important note: mod1::val will be 0, because global variables are being calculated during the import.
# When module import finishes, atomic values (like nil, integers, booleans, floats) will be immutable.
# If you're working with global values a lot and want them to accessible, make getters.

print(mod1::val, mod1::get())   # 0 7
