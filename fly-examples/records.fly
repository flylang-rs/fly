record City {
    public name;
    public latitude;
    public longitude;
}

func City::with_heart() {
    return self.name + " <3"
}


helsinki = new City {
	name: "Helsinki",
	latitude: 60.192059,
	longitude: 24.945831
}

print(helsinki.name + " " + helsinki.latitude.to_string() + " " + helsinki.longitude.to_string());
