record City {
    public name;
    public latitude;
    public longitude;
}

func City::with_heart() {
    return self.name + " <3"
}

# For `print` compatibility
func City::to_string() { 
    return self.name + " " + self.latitude.to_string() + " " + self.longitude.to_string()
}


helsinki = new City {
	name: "Helsinki",
	latitude: 60.192059,
	longitude: 24.945831
}

print(helsinki);
